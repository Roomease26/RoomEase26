rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATORS
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.phone is string && data.phone.size() <= 15 &&
             data.role in ['user', 'admin'] &&
             (data.loginExpiry == null || data.loginExpiry is string) &&
             (data.paymentExpiry == null || data.paymentExpiry is string);
    }

    function isValidListing(data) {
      return data.city is string && data.city.size() <= 100 &&
             data.area is string && data.area.size() <= 100 &&
             data.address is string && data.address.size() <= 500 &&
             data.ownerUid == request.auth.uid &&
             data.createdAt is string;
    }

    function isValidChat(data) {
      return data.listingId is string &&
             data.participants is list &&
             data.participants.size() == 2 &&
             request.auth.uid in data.participants;
    }

    function isValidMessage(data) {
      return data.text is string && data.text.size() <= 2000 &&
             data.senderUid == request.auth.uid &&
             data.createdAt is string;
    }

    function isValidPayment(data) {
      return data.userId == request.auth.uid &&
             data.amount is number &&
             data.status is string &&
             data.createdAt is string;
    }

    // -------------------------------------------------------------------------
    // MATCH BLOCKS
    // -------------------------------------------------------------------------
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins Collection
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or service account
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        (isOwner(userId) && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['phone', 'loginExpiry', 'paymentExpiry', 'role'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Listings Collection
    match /listings/{listingId} {
      allow read: if true; // Public access to listings
      allow create: if isSignedIn() && isValidListing(incoming());
      allow update: if isSignedIn() && (isOwner(existing().ownerUid) && isValidListing(incoming())) || isAdmin();
      allow delete: if isSignedIn() && (isOwner(existing().ownerUid) || isAdmin());
    }

    // Chats Collection
    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in existing().participants || isAdmin());
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update: if isSignedIn() && (request.auth.uid in existing().participants || isAdmin());
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) && isValidMessage(incoming());
      }
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow create: if isSignedIn() && isValidPayment(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
