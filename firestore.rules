rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATORS
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.phone is string && data.phone.size() <= 15 &&
             data.role in ['finder', 'owner', 'admin'] &&
             (data.roleChosen == null || data.roleChosen is bool) &&
             (data.acceptedTerms == null || data.acceptedTerms is bool) &&
             (data.loginExpiry == null || data.loginExpiry is string) &&
             (data.paymentExpiry == null || data.paymentExpiry is string) &&
             (data.language == null || data.language is string) &&
             (data.loginTime == null || data.loginTime is string) &&
             (data.lastActive == null || data.lastActive is string) &&
             (data.selectedCity == null || data.selectedCity is string) &&
             (data.subscriptionStatus == null || data.subscriptionStatus in ['active', 'expired', 'none']) &&
             (data.subscriptionActive == null || data.subscriptionActive is bool) &&
             (data.expiryDate == null || data.expiryDate is string);
    }

    function isValidListing(data) {
      return data.city is string && data.city.size() <= 100 &&
             data.area is string && data.area.size() <= 100 &&
             data.address is string && data.address.size() <= 500 &&
             data.ownerUid == request.auth.uid &&
             data.createdAt is string;
    }

    function isValidChat(data) {
      return data.listingId is string &&
             data.participants is list &&
             data.participants.size() == 2 &&
             request.auth.uid in data.participants;
    }

    function isValidMessage(data) {
      return data.text is string && data.text.size() <= 2000 &&
             data.senderUid == request.auth.uid &&
             data.createdAt is string;
    }

    function isValidPayment(data) {
      return data.userId == request.auth.uid &&
             data.amount is number &&
             data.status is string &&
             data.createdAt is string;
    }

    // -------------------------------------------------------------------------
    // MATCH BLOCKS
    // -------------------------------------------------------------------------
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins Collection
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && 
                    // Prevent common users from making themselves admins via role field
                    (isAdmin() || incoming().role == existing().role || existing().role != 'admin');
    }

    // Listings Collection
    match /listings/{listingId} {
      allow read: if true; 
      allow create: if isSignedIn() && isValidListing(incoming());
      allow update: if isSignedIn() && (existing().ownerUid == request.auth.uid || isAdmin()) && isValidListing(incoming());
      allow delete: if isSignedIn() && (existing().ownerUid == request.auth.uid || isAdmin());
    }

    // Chats Collection
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in existing().participants && isValidChat(incoming());
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && isValidMessage(incoming());
      }
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidPayment(incoming());
      allow update, delete: if isAdmin();
    }

    // Areas Collection
    match /areas/{areaId} {
      allow read: if true;
      allow create: if isSignedIn(); // Allow contributors
      allow update, delete: if isAdmin();
    }
  }
}
