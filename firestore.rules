rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATORS
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.phone is string && data.phone.size() <= 15 &&
             data.role in ['user', 'admin'] &&
             (data.loginExpiry == null || data.loginExpiry is string) &&
             (data.paymentExpiry == null || data.paymentExpiry is string) &&
             (data.language == null || data.language is string) &&
             (data.loginTime == null || data.loginTime is string) &&
             (data.lastActive == null || data.lastActive is string) &&
             (data.selectedCity == null || data.selectedCity is string) &&
             (data.subscriptionStatus == null || data.subscriptionStatus in ['active', 'expired', 'none']) &&
             (data.subscriptionActive == null || data.subscriptionActive is bool) &&
             (data.expiryDate == null || data.expiryDate is string) &&
             (data.acceptedTerms == null || data.acceptedTerms is bool) &&
             (data.uid == null || data.uid is string);
    }

    function isValidListing(data) {
      return data.city is string && data.city.size() <= 100 &&
             data.area is string && data.area.size() <= 100 &&
             data.address is string && data.address.size() <= 500 &&
             data.createdAt is string;
    }

    function isValidChat(data) {
      return data.listingId is string &&
             data.participants is list &&
             data.participants.size() == 2;
    }

    function isValidMessage(data) {
      return data.text is string && data.text.size() <= 2000 &&
             data.senderUid is string &&
             data.createdAt is string;
    }

    function isValidPayment(data) {
      return data.userId is string &&
             data.amount is number &&
             data.status is string &&
             data.createdAt is string;
    }

    // -------------------------------------------------------------------------
    // MATCH BLOCKS
    // -------------------------------------------------------------------------
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins Collection
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console or service account
    }

    // Users Collection
    match /Users/{userId} {
      allow read: if true; // Allow reading user profiles for chat/identification
      allow create: if true; // Allow registration
      allow update: if true; // Allow updates (could be more restrictive but keeping it simple for prototype)
    }

    // Listings Collection
    match /listings/{listingId} {
      allow read: if true; // Public access to listings
      allow create, update, delete: if true; // Keeping it simple for prototype
    }

    // Chats Collection
    match /chats/{chatId} {
      allow read, create, update: if true;
      
      match /messages/{messageId} {
        allow read, create: if true;
      }
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
